<?xml version="1.0" encoding="UTF-8" ?>
<XMLDB PATH="local/orchestrator/db" VERSION="20260308" COMMENT="XMLDB file for Moodle local_orchestrator"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:noNamespaceSchemaLocation="../../../lib/xmldb/xmldb.xsd"
>
  <TABLES>
    <TABLE NAME="local_orch_stud_profile" COMMENT="Maintains long-term student profile">
      <FIELDS>
        <FIELD NAME="id" TYPE="int" LENGTH="10" NOTNULL="true" SEQUENCE="true"/>
        <FIELD NAME="userid" TYPE="int" LENGTH="10" NOTNULL="true" SEQUENCE="false"/>
        <FIELD NAME="courseid" TYPE="int" LENGTH="10" NOTNULL="true" SEQUENCE="false"/>
        <FIELD NAME="level" TYPE="char" LENGTH="255" NOTNULL="false" SEQUENCE="false"/>
        <FIELD NAME="mastery_by_kc" TYPE="text" NOTNULL="false" SEQUENCE="false" COMMENT="JSON object"/>
        <FIELD NAME="misconceptions" TYPE="text" NOTNULL="false" SEQUENCE="false" COMMENT="JSON array"/>
        <FIELD NAME="preferences" TYPE="text" NOTNULL="false" SEQUENCE="false" COMMENT="JSON object"/>
        <FIELD NAME="integrity" TYPE="text" NOTNULL="false" SEQUENCE="false" COMMENT="JSON object"/>
        <FIELD NAME="timecreated" TYPE="int" LENGTH="10" NOTNULL="true" SEQUENCE="false"/>
        <FIELD NAME="timemodified" TYPE="int" LENGTH="10" NOTNULL="true" SEQUENCE="false"/>
      </FIELDS>
      <KEYS>
        <KEY NAME="primary" TYPE="primary" FIELDS="id"/>
      </KEYS>
      <INDEXES>
        <INDEX NAME="usercourse" UNIQUE="true" FIELDS="userid, courseid"/>
      </INDEXES>
    </TABLE>
    <TABLE NAME="local_orch_int_summ" COMMENT="Short-term interaction history summaries">
      <FIELDS>
        <FIELD NAME="id" TYPE="int" LENGTH="10" NOTNULL="true" SEQUENCE="true"/>
        <FIELD NAME="userid" TYPE="int" LENGTH="10" NOTNULL="true" SEQUENCE="false"/>
        <FIELD NAME="courseid" TYPE="int" LENGTH="10" NOTNULL="true" SEQUENCE="false"/>
        <FIELD NAME="run_id" TYPE="char" LENGTH="255" NOTNULL="false" SEQUENCE="false"/>
        <FIELD NAME="summary" TYPE="text" NOTNULL="false" SEQUENCE="false"/>
        <FIELD NAME="tags" TYPE="text" NOTNULL="false" SEQUENCE="false" COMMENT="JSON array"/>
        <FIELD NAME="last_targets" TYPE="text" NOTNULL="false" SEQUENCE="false" COMMENT="JSON array"/>
        <FIELD NAME="last_next_steps" TYPE="text" NOTNULL="false" SEQUENCE="false" COMMENT="JSON array"/>
        <FIELD NAME="student_vis_out" TYPE="char" LENGTH="255" NOTNULL="false" SEQUENCE="false"/>
        <FIELD NAME="timecreated" TYPE="int" LENGTH="10" NOTNULL="true" SEQUENCE="false"/>
      </FIELDS>
      <KEYS>
        <KEY NAME="primary" TYPE="primary" FIELDS="id"/>
      </KEYS>
      <INDEXES>
        <INDEX NAME="usercourse" UNIQUE="false" FIELDS="userid, courseid"/>
      </INDEXES>
    </TABLE>
  </TABLES>
</XMLDB>
