<quiz>
<!-- Question: 1 -->
<question type="multichoice">
  <name>
    <text>Programming 101 - Variables</text>
  </name>
  <questiontext format="html">
    <text><![CDATA[<p>Which of the following is a valid variable name in PHP?</p>]]></text>
  </questiontext>
  <answer fraction="100" format="html">
    <text><![CDATA[<p>$myVariable</p>]]></text>
    <feedback format="html">
      <text><![CDATA[<p>Correct! PHP variables start with $.</p>]]></text>
    </feedback>
  </answer>
  <answer fraction="0" format="html">
    <text><![CDATA[<p>myVariable</p>]]></text>
    <feedback format="html">
      <text><![CDATA[<p>Incorrect. Standard variables need a $ prefix.</p>]]></text>
    </feedback>
  </answer>
  <answer fraction="0" format="html">
    <text><![CDATA[<p>123variable</p>]]></text>
    <feedback format="html">
      <text><![CDATA[<p>Incorrect. Variable names cannot start with a number.</p>]]></text>
    </feedback>
  </answer>
</question>

